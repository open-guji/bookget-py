{
  "name": "bookget-ui",
  "version": "0.1.0",
  "description": "React components for managing ancient book downloads with bookget",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
